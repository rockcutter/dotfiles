function chezmoi_commit(){
	chezmoi git -- add .
	chezmoi git -- diff --cached
	echo "commit after 5 seconds..."
	sleep 5
	chezmoi git -- commit -m "$(chezmoi generate git-commit-message)"
	chezmoi git -- push
}

