## abbreviation setting -------------------------------------------------

###  https://qiita.com/aosho235/items/181af4d29b323da0baa1
function expand-alias-and-self-insert() {
  local words=(${(z)LBUFFER})
  local word="${words[1]}"
  local exclude_aliases=(ls ll cp rm)
  # カーソル前の単語がバックスラッシュで始まる場合は除外。ls等は除外
  if [[ ${words[-1][1]} != '\' && ${exclude_aliases[(r)$word]} != "$word" ]]; then
    zle _expand_alias
  fi
  zle self-insert
}

function expand-alias-and-accept-line() {
  zle _expand_alias
  zle accept-line
}

zle -N expand-alias-and-accept-line
bindkey '^M' expand-alias-and-accept-line

zle -N expand-alias-and-self-insert
bindkey ' ' expand-alias-and-self-insert

