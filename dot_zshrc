PROMPT='
%F{green}$ZSH_NEST_INDICATOR%f %F{red}%n%f on %F{yellow}%m%f at %F{red}%D{%Y-%m-%dT%H:%M:%S%z}%f
wd %B%F{green}%~%f%b {$(_git_row_changes_for_prompt)}
$_last_exit_status %F{red}$(_git_branch_for_prompt)%f$ '

