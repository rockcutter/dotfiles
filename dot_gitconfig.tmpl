[user]
	name = rockcutter
	email = {{ .email }}

[alias]
	a = "!f() { cd \"${GIT_PREFIX:-.}\" && git add \"$@\" && git status -s -u; }; f"
	sw = switch
	swf = "!f () { git switch $(git --no-pager branch --sort=-committerdate | fzf); };f"
	s = status
	ss = status -s -u
	s = switch
	cm = commit
	cmm = commit -m
	b = branch
	cdiff = diff --cached
  p = pull
	master = "!f() { if git show-ref --verify --quiet refs/heads/main; then git switch main; elif git show-ref --verify --quiet refs/heads/master; then git switch master; else echo 'main/master ブランチが見つからないよ〜' >&2; return 1; fi; }; f"
	ma = master

[core]
	editor = nvim
	excludesfile = ~/.gitignore_global
  pager = delta

# 少ない行数でも less 形式で表示するために F オプションを除いている
[delta]
    pager = less -RX

[push]
	autoSetupRemote = true

[pull]
	rebase = false

